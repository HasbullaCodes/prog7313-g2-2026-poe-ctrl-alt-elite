<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF6EE"
    android:padding="28dp">

    <TextView
        android:id="@+id/tvBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="←"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#17323A"
        android:padding="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvForgotTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reset Password"
        android:textColor="#17323A"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/etForgotEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.35" />

    <EditText
        android:id="@+id/etForgotEmail"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Enter your email"
        android:inputType="textEmailAddress"
        android:background="@drawable/input_rounded_green"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="#17323A"
        android:textColorHint="#6B8B80"
        app:layout_constraintTop_toBottomOf="@id/tvForgotTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <EditText
        android:id="@+id/etNewPassword"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="New password"
        android:inputType="textPassword"
        android:background="@drawable/input_rounded_green"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="#17323A"
        android:textColorHint="#6B8B80"
        app:layout_constraintTop_toBottomOf="@id/etForgotEmail"
        app:layout_constraintStart_toStartOf="@id/etForgotEmail"
        app:layout_constraintEnd_toEndOf="@id/etForgotEmail"
        android:layout_marginTop="12dp" />

    <EditText
        android:id="@+id/etConfirmNewPassword"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="Confirm new password"
        android:inputType="textPassword"
        android:background="@drawable/input_rounded_green"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:textColor="#17323A"
        android:textColorHint="#6B8B80"
        app:layout_constraintTop_toBottomOf="@id/etNewPassword"
        app:layout_constraintStart_toStartOf="@id/etNewPassword"
        app:layout_constraintEnd_toEndOf="@id/etNewPassword"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnResetPassword"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Reset Password"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#A8D4F8"
        app:layout_constraintTop_toBottomOf="@id/etConfirmNewPassword"
        app:layout_constraintStart_toStartOf="@id/etConfirmNewPassword"
        app:layout_constraintEnd_toEndOf="@id/etConfirmNewPassword"
        android:layout_marginTop="20dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
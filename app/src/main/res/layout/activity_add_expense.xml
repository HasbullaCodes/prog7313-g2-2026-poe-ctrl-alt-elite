<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF6EE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="22dp">

            <TextView
                android:id="@+id/tvBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:padding="6dp"
                android:text="←"
                android:textColor="#17323A"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvExpenseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Add Expense"
                android:textColor="#14333D"
                android:textSize="24sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Record your spending details"
            android:textColor="#14333D"
            android:textSize="13sp"
            android:alpha="0.8"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="22dp" />

        <!-- CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Amount"
                    android:inputType="numberDecimal"
                    android:background="@drawable/input_rounded_green"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#17323A"
                    android:textColorHint="#6B8B80" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:hint="Description"
                    android:background="@drawable/input_rounded_green"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#17323A"
                    android:textColorHint="#6B8B80" />

                <EditText
                    android:id="@+id/etDate"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:hint="Date (DD/MM/YYYY)"
                    android:background="@drawable/input_rounded_green"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#17323A"
                    android:textColorHint="#6B8B80"
                    android:focusable="false"
                    android:clickable="true" />

                <EditText
                    android:id="@+id/etStartTime"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:hint="Start Time (HH:MM)"
                    android:background="@drawable/input_rounded_green"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#17323A"
                    android:textColorHint="#6B8B80" />

                <EditText
                    android:id="@+id/etEndTime"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:hint="End Time (HH:MM)"
                    android:background="@drawable/input_rounded_green"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#17323A"
                    android:textColorHint="#6B8B80" />

                <TextView
                    android:id="@+id/tvCategoryLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Select Category"
                    android:textStyle="bold"
                    android:textColor="#17323A" />

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/input_rounded_green" />

                <Button
                    android:id="@+id/btnPickImage"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="Add Photo"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#17323A"
                    android:backgroundTint="#A8D4F8" />

                <Button
                    android:id="@+id/btnTakePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:text="Take Photo"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#17323A"
                    android:backgroundTint="#A8D4F8" />

                <Button
                    android:id="@+id/btnSaveExpense"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="16dp"
                    android:text="Save Expense"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#17333D" />

                <ImageView
                    android:id="@+id/ivExpenseImage"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/input_rounded_green" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>